amends "package://github.com/jdx/hk/releases/download/v1.44.0/hk@1.44.0#/Config.pkl"

hooks = new {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = new {
      ["fission-sync"] = new Step {
        glob = List(
          "kubernetes/apps/fission/functions/**/*.py",
          "kubernetes/apps/fission/functions/**/pyproject.toml"
        )
        check = "task --silent fission:check-packages -- {{files}}"
        fix = "task --silent fission:sync-packages -- {{files}}"
      }
    }
  }
}
