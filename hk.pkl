amends "package://github.com/jdx/hk/releases/download/v1.44.0/hk@1.44.0#/Config.pkl"

hooks = new {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = new {
      ["fission-sync"] = new Step {
        glob = "kubernetes/apps/fission/functions/**/*.py"
        fix = "task fission:sync-packages -- {{files}}"
      }
    }
  }
}
