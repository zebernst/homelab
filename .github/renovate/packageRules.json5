{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: ["Loose versioning for non-semver packages"],
      matchDatasources: ["docker"],
      versioning: "loose",
      matchPackagePatterns: ["plex"],
    },
    {
      description: ["Custom schedule for frequently updated container digests"],
      matchDatasources: ["docker"],
      matchPackagePatterns: ["postgresql"],
      matchUpdateTypes: ["digest"],
      schedule: ["every 3 months on the first day of the month"],
    },
    {
      description: ["Separate minor and patch updates for Talos to enforce safe upgrade paths"],
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/siderolabs/installer", "ghcr.io/siderolabs/kubelet"],
      separateMajorMinor: true,
      separateMinorPatch: true,
    },
    {
      description: ["Group Kubernetes control plane component images into a single PR"],
      matchDatasources: ["docker"],
      matchPackageNames: [
        "registry.k8s.io/kube-apiserver",
        "registry.k8s.io/kube-controller-manager",
        "registry.k8s.io/kube-proxy",
        "registry.k8s.io/kube-scheduler",
      ],
      groupName: "kubernetes control plane",
      separateMajorMinor: true,
      separateMinorPatch: true,
    },
  ],
}
