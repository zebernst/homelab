{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customManagers: [
    {
      customType: "regex",
      description: "Process annotated dependencies referenced by URL (not covered by the home-operations annotated preset)",
      managerFilePatterns: ["/\\.ya?ml(?:\\.j2)?$/"],
      matchStrings: [
        // # renovate: datasource=github-releases depName=kubernetes-sigs/gateway-api
        // https://github.com/kubernetes-sigs/gateway-api/releases/download/v1.5.0/experimental-install.yaml
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n.+/(?<currentValue>[v\\d][^/]+)/",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
    },
  ],
}
